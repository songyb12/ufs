# ============================================
# VIBE Service - Environment Configuration
# ============================================
# Copy to .env and customize values.
# All variables have defaults — only set what you need to override.

# ── General ──
SERVICE_NAME=vibe
SERVICE_PORT=8001
VERSION=0.1.0
DEBUG=false

# ── Database ──
DB_PATH=/app/data/vibe.db
DB_BACKUP_DIR=/app/data/backups
DB_BACKUP_KEEP_DAYS=7

# ── Discord Notifications ──
DISCORD_WEBHOOK_URL=

# ── Hard Limit Thresholds (grid search optimized) ──
RSI_HARD_LIMIT=65.0
RSI_BUY_THRESHOLD_KR=45.0
RSI_BUY_THRESHOLD_US=50.0
DISPARITY_HARD_LIMIT=105.0

# ── Scheduler (UTC hours) ──
SCHEDULER_ENABLED=true
KR_PIPELINE_HOUR_UTC=7       # 16:00 KST
KR_PIPELINE_MINUTE=0
US_PIPELINE_HOUR_UTC=22      # 17:00 EST (winter)
US_PIPELINE_MINUTE=0
MACRO_COLLECT_HOUR_UTC=5
MACRO_COLLECT_MINUTE=0

# ── Data Collection ──
PRICE_HISTORY_DAYS=200
COLLECTION_DELAY_SECONDS=1.0
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=2.0

# ── Signal Scoring Weights ──
WEIGHT_TECHNICAL=0.35
WEIGHT_MACRO=0.20
WEIGHT_FUND_FLOW=0.25
WEIGHT_FUNDAMENTAL=0.20
WEIGHT_SENTIMENT=0.10
WEIGHT_NEWS=0.0

# ── Signal Thresholds ──
SIGNAL_BUY_THRESHOLD=15.0
SIGNAL_SELL_THRESHOLD=-15.0

# ── Red-Team ──
RED_TEAM_ENABLED=true

# ── Backtesting ──
BACKTEST_DEFAULT_DAYS=365
BACKTEST_TRADE_EXIT_DAYS=20
BACKTEST_STOP_LOSS_PCT=-7.0

# ── Position Sizing ──
PORTFOLIO_TOTAL=100000000       # 1억 KRW
MAX_SINGLE_POSITION_PCT=0.10
MAX_SECTOR_EXPOSURE_PCT=0.30
POSITION_SIZING_METHOD=fixed_fraction

# ── Event Calendar ──
EVENT_SUPPRESS_DAYS=3
EVENT_SUPPRESS_ENABLED=true

# ── Sentiment ──
SENTIMENT_FETCH_ENABLED=true

# ── LLM (Optional — for AI Red-Team, Explanations, Scenarios) ──
LLM_RED_TEAM_ENABLED=false
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_API_KEY=                    # Your API key (keep secret!)
LLM_MODEL=claude-haiku-4-5-20251001

# ── Korean Explanations ──
EXPLANATION_ALWAYS_ENABLED=true
LLM_EXPLANATION_ENABLED=false
LLM_EXPLANATION_MODEL=

# ── Portfolio Scenarios ──
PORTFOLIO_SCENARIOS_ENABLED=true
LLM_SCENARIO_ENABLED=false

# ── US Fund Flow ──
US_FUND_FLOW_ENABLED=true

# ── API Authentication (optional) ──
API_KEY=                        # Set to enable auth; empty = no auth
API_AUTH_ENABLED=false

# ── CORS (comma-separated extra origins) ──
CORS_EXTRA_ORIGINS=

# ── News Analysis ──
NEWS_ENABLED=true
NEWS_MAX_ARTICLES=5

# ── Data Retention (days) ──
RETENTION_PRICE_DAYS=400
RETENTION_SIGNAL_DAYS=365
RETENTION_NEWS_DAYS=90
RETENTION_PIPELINE_RUNS_DAYS=90

# ── Performance Tracking ──
PERFORMANCE_TRACKING_ENABLED=true

# ── Structured Logging (production) ──
LOG_FORMAT=text                 # text | json
LOG_LEVEL=INFO
