# ============================================
# UFS Master Core Ecosystem - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- General ---
DEBUG=false

# --- Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- VIBE Hard Limits (optional overrides) ---
# RSI_HARD_LIMIT=65.0
# RSI_BUY_THRESHOLD_KR=50.0
# RSI_BUY_THRESHOLD_US=55.0
# DISPARITY_HARD_LIMIT=105.0

# --- VIBE Scheduler (UTC hours, optional overrides) ---
# KR_PIPELINE_HOUR_UTC=7
# KR_PIPELINE_MINUTE=0
# US_PIPELINE_HOUR_UTC=22
# US_PIPELINE_MINUTE=0
# MACRO_COLLECT_HOUR_UTC=5
# MACRO_COLLECT_MINUTE=0

# --- VIBE Signal Weights (optional overrides) ---
# WEIGHT_TECHNICAL=0.35
# WEIGHT_MACRO=0.20
# WEIGHT_FUND_FLOW=0.25
# WEIGHT_FUNDAMENTAL=0.20

# --- VIBE Data Collection (optional overrides) ---
# PRICE_HISTORY_DAYS=200
# COLLECTION_DELAY_SECONDS=1.0
# MAX_RETRY_ATTEMPTS=3
